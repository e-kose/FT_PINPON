            },
            "in": "header",
            "name": "x-user-id",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully left matchmaking queue",
            "content": {
              "application/json": {
                "schema": {
                  "description": "Successfully left matchmaking queue",
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/game/matchmaking/status": {
      "get": {
