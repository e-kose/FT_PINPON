{
    "info": {
        "_postman_id": "d4e8c1b2-a9f6-4b10-8654-abcdef123456",
        "name": "Full Project API (All Services)",
        "description": "Comprehensive collection for all microservices in the project. Features automated JWT token handling for authenticated endpoints.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Authentication Service",
            "item": [
                {
                    "name": "Login and Globally Save Token",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "    const responseBody = pm.response.json();",
                                    "    if (responseBody && responseBody.accessToken) {",
                                    "        pm.collectionVariables.set(\"jwt_token\", responseBody.accessToken);",
                                    "        console.log(\"Access Token saved globally.\");",
                                    "    } else {",
                                    "        console.error(\"Response did not contain 'accessToken'.\");",
                                    "    }",
                                    "} else {",
                                    "    console.error(\"Login failed with status: \" + pm.response.code);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"testuser@example.com\",\n    \"password\": \"password123\"\n}"
                        },
                        "url": {
                            "raw": "http://localhost:3000/auth/login",
                            "protocol": "http",
                            "host": [
                                "localhost"
                            ],
                            "port": "3000",
                            "path": [
                                "auth",
                                "login"
                            ]
                        },
                        "description": "Log in with a user to get a JWT. The script will save the token for all other requests in this collection."
                    },
                    "response": []
                },
                {
