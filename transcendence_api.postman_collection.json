              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "array"
                    },
                    "count": {
                      "type": "number"
                    },
                    "total_active": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/game/{id}": {
      "get": {
        "tags": [
