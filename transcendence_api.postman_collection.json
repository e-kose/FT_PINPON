{
  "openapi": "3.0.3",
  "info": {
    "title": "Game Service API",
    "description": "Pong game service - local, online and tournament modes",
    "version": "1.0.0"
  },
  "components": {
    "schemas": {

    }
  },
  "paths": {
    "/game/local/create": {
      "post": {
        "tags": [
          "game"
        ],
        "description": "Create a local game with guest players",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "player1_nickname",
                  "player2_nickname"
                ],
                "properties": {
                  "player1_nickname": {
                    "type": "string",
                    "minLength": 2,
                    "maxLength": 20
                  },
                  "player2_nickname": {
                    "type": "string",
                    "minLength": 2,
                    "maxLength": 20
                  },
                  "max_score": {
                    "type": "number",
                    "minimum": 5,
                    "maximum": 21,
                    "default": 11
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Game created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "description": "Game created successfully",
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/game/": {
      "get": {
        "tags": [
          "game"
        ],
        "description": "Get all games with optional filters",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "enum": [
                "waiting",
                "ready",
                "playing",
                "finished",
                "cancelled"
              ]
            },
            "in": "query",
            "name": "status",
            "required": false
          },
          {
            "schema": {
              "type": "string",
              "enum": [
                "local",
                "online",
                "tournament"
              ]
            },
            "in": "query",
            "name": "game_mode",
            "required": false
          },
          {
            "schema": {
              "type": "number",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            },
            "in": "query",
            "name": "limit",
            "required": false
          },
          {
            "schema": {
              "type": "number",
              "minimum": 0,
              "default": 0
            },
            "in": "query",
            "name": "offset",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/game/active": {
      "get": {
        "tags": [
          "game"
        ],
        "description": "Get all active games",
        "responses": {
          "200": {
            "description": "Default Response",
